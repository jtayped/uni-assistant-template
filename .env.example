# copy to .env and edit. .env is gitignored — never commit it.

# iana timezone name (docker containers default to utc)
TIMEZONE=Europe/Madrid

# optional: set an api key to restrict access if you ever expose the server
# beyond localhost. leave empty (the default) for no auth.
# generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# API_KEY=
